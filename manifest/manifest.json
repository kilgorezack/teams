{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "6cd9880c-ff40-4b2a-a601-17a72eb18fdd",
  "packageName": "com.quorum.app",
  "developer": {
    "name": "Quorum",
    "websiteUrl": "https://quorum.summitlabs.one",
    "privacyUrl": "https://quorum.summitlabs.one/#privacy",
    "termsOfUseUrl": "https://quorum.summitlabs.one/#terms"
  },
  "name": {
    "short": "Quorum",
    "full": "Quorum — Meeting Democracy"
  },
  "description": {
    "short": "Vote to end meetings or remove participants.",
    "full": "Quorum gives every meeting participant a democratic vote to end the meeting or nominate someone for removal. Real-time voting via the side panel."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#6264A7",
  "configurableTabs": [
    {
      "configurationUrl": "https://quorum.summitlabs.one/app/config.html",
      "canUpdateConfiguration": false,
      "scopes": ["groupchat"],
      "context": ["meetingSidePanel"]
    }
  ],
  "staticTabs": [
    {
      "entityId": "quorum-sidepanel",
      "name": "Quorum",
      "contentUrl": "https://quorum.summitlabs.one/app/index.html",
      "scopes": ["groupchat"],
      "context": ["meetingSidePanel"]
    }
  ],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": [
    "quorum.summitlabs.one",
    "*.supabase.co"
  ],
  "meetingExtensionDefinition": {
    "scenes": [],
    "supportsStreaming": false
  }
}
